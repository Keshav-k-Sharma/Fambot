# Copy to .env and set values. See README Environment variables.

FIREBASE_PROJECT_ID=your-firebase-project-id
GOOGLE_APPLICATION_CREDENTIALS=firebase-admin.json
FIREBASE_WEB_API_KEY=your-firebase-web-api-key
FAMBOT_JWT_SECRET=generate-with-openssl-rand-hex-32
FAMBOT_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

HOST=0.0.0.0
PORT=8000

# Optional: override default repo-root cardiovascular_model.pkl
# MODEL_PATH=/absolute/path/to/cardiovascular_model.pkl

# Optional local-only shortcuts (do not use in production)
# FAMBOT_SKIP_AUTH=1
# FAMBOT_DEV_UID=dev-user
# FAMBOT_SKIP_FIRESTORE=1
